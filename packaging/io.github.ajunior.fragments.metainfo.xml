<component type="desktop-application">
  <id>io.github.ajunior.fragments</id>
  <name>Fragments</name>
  <summary>Scripted playback for media fragments</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <developer id="io.github.ajunior">
    <name>Adjamilton Junior</name>
  </developer>
  <launchable type="desktop-id">io.github.ajunior.fragments.desktop</launchable>
  <url type="homepage">https://github.com/ajunior/fragments</url>
  <url type="bugtracker">https://github.com/ajunior/fragments/issues</url>
  <description>
    <p>
      Fragments is a Qt/QML media player for scripted playback of video and audio snippets.
      It lets users build playlists from selected ranges of source media, trim fragments
      visually, label and annotate cues, recover missing media, and export a combined MP4
      render through ffmpeg.
    </p>
  </description>
